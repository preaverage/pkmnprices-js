{
  "name": "@pkmnprices/sdk",
  "version": "1.0.4",
  "description": "TypeScript/JavaScript client for the Pkmn Prices API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/preaverage/pkmnprices-js.git"
  },
  "homepage": "https://github.com/preaverage/pkmnprices-js#readme",
  "bugs": {
    "url": "https://github.com/preaverage/pkmnprices-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pokemon",
    "tcg",
    "pricing",
    "tcgplayer",
    "cardmarket",
    "ebay",
    "sdk",
    "api"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
